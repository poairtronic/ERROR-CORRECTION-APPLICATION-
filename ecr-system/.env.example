# Server Configuration
PORT=3000
NODE_ENV=production

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=8h

# Email Configuration (Gmail SMTP or Google Apps Script HTTPS proxy)
# Create an App Password at https://myaccount.google.com/apppasswords
# Or set GMAIL_SCRIPT_URL to use the Google Apps Script Web App HTTPS proxy
GMAIL_SCRIPT_URL=
GMAIL_SCRIPT_TOKEN=
GMAIL_APP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=

# Scheduler Configuration
NOTIFICATION_RETRY_INTERVAL_MIN=1

# Frontend deep links
FRONTEND_URL=
