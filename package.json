{
  "name": "ecr-monolithic",
  "version": "1.0.0",
  "description": "Monolithic deployment for ECR System",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "frontend",
    "ecr-system"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "start": "npm run start:prod --workspace=ecr-system",
    "render-build": "npm install --include=dev && npm run build"
  }
}
