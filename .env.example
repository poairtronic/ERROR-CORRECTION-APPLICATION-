# ==============================================================================
# ECR System — Unified Environment Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (ecr-system)
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Database Connection (Neon PostgreSQL URI)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=8h

# Email Configuration
# Mode 1: Google Apps Script Web App HTTPS Proxy (Recommended for Render free tier)
GMAIL_SCRIPT_URL=
GMAIL_SCRIPT_TOKEN=

# Mode 2: Gmail SMTP Fallback
GMAIL_APP_PASSWORD=

# Sender Identity
EMAIL_FROM=
EMAIL_FROM_NAME="Airtronics ECR System"

# Frontend Link Deep Linking (used in email templates)
FRONTEND_URL=

# ------------------------------------------------------------------------------
# Frontend Configuration (frontend)
# ------------------------------------------------------------------------------
# Vite api proxy/base path. Leave empty or /api for local dev proxies.
VITE_API_BASE=
